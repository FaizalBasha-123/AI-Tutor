static PG_POOL: OnceCell<r2d2::Pool<PostgresConnectionManager<NoTls>>> = OnceCell::new();

fn get_pg_client(url: &str) -> AnyResult<r2d2::PooledConnection<PostgresConnectionManager<NoTls>>> {
    let pool = PG_POOL.get_or_init(|| {
        let manager = PostgresConnectionManager::new(
            url.parse().expect("Failed to parse Postgres URL"),
            NoTls,
        );
        r2d2::Pool::builder()
            .max_size(20)
            .build(manager)
            .expect("Failed to create Postgres connection pool")
    });
    
    pool.get().map_err(|e| anyhow!("Failed to get connection from pool: {}", e))
}

pub struct FileStorage {
    root: PathBuf,
    postgres_url: String,
    postgres_ready: Arc<AtomicBool>,
    job_lock: Arc<Mutex<()>>,
}

impl FileStorage {
    pub fn with_databases(
        root: impl Into<PathBuf>,
        _lesson_db_path: Option<PathBuf>,
        _runtime_db_path: Option<PathBuf>,
        _job_db_path: Option<PathBuf>,
        postgres_url: Option<String>,
    ) -> Self {
        Self {
            root: root.into(),
            postgres_url: postgres_url.expect("Postgres URL is mandatory"),
            postgres_ready: Arc::new(AtomicBool::new(false)),
            job_lock: Arc::new(Mutex::new(())),
        }
    }

    pub fn root_dir(&self) -> &Path {
        &self.root
    }

    pub async fn ensure_postgres_ready(&self) -> AnyResult<()> {
        let url = self.postgres_url.clone();
        let ready = Arc::clone(&self.postgres_ready);
        tokio::task::spawn_blocking(move || {
            if ready.load(Ordering::Acquire) {
                return Ok(());
            }
            let _client = get_pg_client(&url)?;
            ready.store(true, Ordering::Release);
            Ok(())
        }).await?
    }

    // Helper methods for conversion...
    fn tutor_account_status_to_db(status: &TutorAccountStatus) -> &'static str {
        match status {
            TutorAccountStatus::Active => "active",
            TutorAccountStatus::Suspended => "suspended",
            TutorAccountStatus::PendingVerification => "pending_verification",
        }
    }

    fn tutor_account_status_from_db(status: &str) -> TutorAccountStatus {
        match status {
            "active" => TutorAccountStatus::Active,
            "suspended" => TutorAccountStatus::Suspended,
            _ => TutorAccountStatus::PendingVerification,
        }
    }
}

#[async_trait]
impl TutorAccountRepository for FileStorage {
    async fn save_tutor_account(&self, account: &TutorAccount) -> Result<(), String> {
        let postgres_url = self.postgres_url.clone();
        let account = account.clone();
        tokio::task::spawn_blocking(move || {
            let mut client = get_pg_client(&postgres_url).map_err(|e| e.to_string())?;
            client.execute(
                "INSERT INTO tutor_accounts (id, email, google_id, status, created_at, updated_at)
                 VALUES ($1, $2, $3, $4, $5, $6)
                 ON CONFLICT (id) DO UPDATE SET
                     email = EXCLUDED.email,
                     google_id = EXCLUDED.google_id,
                     status = EXCLUDED.status,
                     updated_at = EXCLUDED.updated_at",
                &[
                    &account.id,
                    &account.email,
                    &account.google_id,
                    &Self::tutor_account_status_to_db(&account.status),
                    &account.created_at,
                    &account.updated_at,
                ],
            ).map_err(|e| e.to_string())?;
            Ok(())
        }).await.map_err(|e| e.to_string())?
    }

    async fn get_tutor_account(&self, id: &str) -> Result<Option<TutorAccount>, String> {
        let postgres_url = self.postgres_url.clone();
        let id = id.to_string();
        tokio::task::spawn_blocking(move || {
            let mut client = get_pg_client(&postgres_url).map_err(|e| e.to_string())?;
            let row = client.query_opt(
                "SELECT id, email, google_id, status, created_at, updated_at FROM tutor_accounts WHERE id = $1",
                &[&id],
            ).map_err(|e| e.to_string())?;
            
            Ok(row.map(|r| TutorAccount {
                id: r.get(0),
                email: r.get(1),
                google_id: r.get(2),
                status: Self::tutor_account_status_from_db(r.get(3)),
                created_at: r.get(4),
                updated_at: r.get(5),
                phone_number: None,
                phone_verified: false,
            }))
        }).await.map_err(|e| e.to_string())?
    }

    async fn get_tutor_account_by_email(&self, email: &str) -> Result<Option<TutorAccount>, String> {
        let postgres_url = self.postgres_url.clone();
        let email = email.to_string();
        tokio::task::spawn_blocking(move || {
            let mut client = get_pg_client(&postgres_url).map_err(|e| e.to_string())?;
            let row = client.query_opt(
                "SELECT id, email, google_id, status, created_at, updated_at FROM tutor_accounts WHERE email = $1",
                &[&email],
            ).map_err(|e| e.to_string())?;
            
            Ok(row.map(|r| TutorAccount {
                id: r.get(0),
                email: r.get(1),
                google_id: r.get(2),
                status: Self::tutor_account_status_from_db(r.get(3)),
                created_at: r.get(4),
                updated_at: r.get(5),
                phone_number: None,
                phone_verified: false,
            }))
        }).await.map_err(|e| e.to_string())?
    }

    async fn list_tutor_accounts(&self) -> Result<Vec<TutorAccount>, String> {
        let postgres_url = self.postgres_url.clone();
        tokio::task::spawn_blocking(move || {
            let mut client = get_pg_client(&postgres_url).map_err(|e| e.to_string())?;
            let rows = client.query(
                "SELECT id, email, google_id, status, created_at, updated_at FROM tutor_accounts",
                &[],
            ).map_err(|e| e.to_string())?;
            
            Ok(rows.into_iter().map(|r| TutorAccount {
                id: r.get(0),
                email: r.get(1),
                google_id: r.get(2),
                status: Self::tutor_account_status_from_db(r.get(3)),
                created_at: r.get(4),
                updated_at: r.get(5),
                phone_number: None,
                phone_verified: false,
            }).collect())
        }).await.map_err(|e| e.to_string())?
    }
}

